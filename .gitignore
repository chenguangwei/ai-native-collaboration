# =================================================================
# AI-原生项目 .gitignore
# 基于 https://github.com/github/gitignore
# =================================================================

# -------------------- 操作系统 --------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# -------------------- Node.js --------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock

# -------------------- 环境变量 --------------------
.env
.env.local
.env.*.local
*.env

# -------------------- IDE --------------------
.vscode/
.idea/
*.sublime-*

# -------------------- 构建产物 --------------------
dist/
build/
.next/
.nuxt/
output/
*.tsbuildinfo

# -------------------- 测试与覆盖率 --------------------
coverage/
.nyc_output/
*.test.js
*.spec.js

# -------------------- 日志与缓存 --------------------
logs/
*.log
.cache/
tmp/

# -------------------- 数据库与存储 --------------------
*.db
*.sqlite
*.sql
data/
uploads/

# -------------------- 临时文件 --------------------
tmp/
temp/
*.tmp

# 本地 AI 配置覆盖（不提交）
CLAUDE.local.md
.claude/settings.local.json
.gstack/
graphify-out/
